rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /hommes/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /actions/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /evenements/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Paramètres site (ex. inscription ouverte) — lecture publique pour masquer le bouton « S’inscrire »
    match /config/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Annuaire des comptes admin (rempli à la connexion) — visible seulement si connecté
    match /admins/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
